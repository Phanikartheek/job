{
    "buildCommand": "npm install && npm run build",
    "outputDirectory": "dist",
    "installCommand": "npm install --legacy-peer-deps",
    "framework": "vite",
    "nodeVersion": "18.x",
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://jobguard-api-qgxe.onrender.com/api/:path*"
        }
    ],
    "env": {
        "VITE_API_URL": "@vite_api_url"
    }
}

