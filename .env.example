# Frontend Environment Variables (.env.local in root)
# Copy this file to .env.local and fill in your values for local development

# Vercel Environment Variables (set in Vercel Dashboard)
VITE_API_URL=https://jobguard-api-qgxe.onrender.com

# Supabase Configuration (Vercel Project Settings)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Backend Flask API URL (only needed for local dev)
VITE_LOCAL_API=http://localhost:5000
